   > मरी_पसदीदा_फाइल.f90,
   > Mi_archivo_favorito.c,
   > ملفي_المفضل.h,
   > Mon_fichier_préféré.f90,
   > আমার_পরিয_ফাইল,
   > Meu_arquivo_favorito,
   > Мой_любимый_файл,
   > میری_پسندیدہ_فائل.pdf,
