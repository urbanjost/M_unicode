.PHONY: ship
ship:
	: make easily distributed archive files of manpages
	mkdir -p ../docs; \
	 cd ../man/;    gzip */*.?m_unicode; \
	 gzip -r ../docs/manpages.zip   */*m_unicode*.gz; \
	 tar cvfz ../docs/manpages.tgz */*m_unicode*.gz; \
	 gunzip */*.?m_unicode.gz

